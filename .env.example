# === BrainrotBot 設定 ===
# このファイルをコピーして「.env」を作り、値を埋める。
# .env は絶対にGitにコミットしない（.gitignore済み）。

# Discord Developer Portal の Bot トークン（秘密！）
DISCORD_TOKEN=ここにBotトークンを貼る

# アプリID（BrainrotBot のクライアントID）
CLIENT_ID=1520867492925276180

# コマンドを登録するサーバーID。
#   テスト時=NONEのID / 本番=ブレインロットファイトのID（1456356183613898803）
#   空にすると参加中の全サーバーに登録される（本番では必ず指定推奨）
GUILD_ID=

# 図鑑(characters.json)の場所。
#   本番(Linux VM)では実ファイルの絶対パスを指定（例: /home/USER/brainrot-bot/characters.json）
#   未設定だとローカル開発用のWindowsパスを使う
CATALOG_PATH=
